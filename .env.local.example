# ═══════════════════════════════════════
# CarrosselAI — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ═══════════════════════════════════════

# URL pública da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ───────────────────────────
# Encontre em: https://supabase.com/dashboard → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# ─── OpenAI ─────────────────────────────
# Encontre em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Nanobana 2 API ─────────────────────
# API para geração de imagens com IA
NANOBANA_API_KEY=sua-chave-nanobana-aqui

# ─── QStash (Upstash) ───────────────────
# Para agendamento de posts — https://console.upstash.com/qstash
QSTASH_TOKEN=seu-token-qstash-aqui
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# ─── Instagram Graph API ────────────────
# Configure em: https://developers.facebook.com/
# Requires: Instagram Business Account + Facebook App
INSTAGRAM_USER_ID=seu-instagram-user-id
INSTAGRAM_ACCESS_TOKEN=seu-access-token-longa-duracao
